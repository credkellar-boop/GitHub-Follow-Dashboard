# GitHub
GITHUB_USERNAME=your_username
GITHUB_TOKEN=your_personal_access_token

# Webhooks & Messaging
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# WhatsApp Business Cloud API
WA_TOKEN=your_meta_permanent_token
WA_PHONE_ID=your_whatsapp_phone_number_id
WA_RECIPIENT=14155551234 # Your phone number (E.164 format, no +)

# Hootsuite REST API
HOOTSUITE_TOKEN=your_hootsuite_oauth_token
HOOTSUITE_PROFILE_ID=your_twitter_or_linkedin_profile_id
